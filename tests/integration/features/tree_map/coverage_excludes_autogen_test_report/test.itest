RUN: %strictdoc export %S --output-dir %T | filecheck %s --dump-input=fail

# The ingested JUnit report is published as an autogenerated test-report document.
CHECK: Published: Test report: hello_world_crate

# The tree map screen is generated.
RUN: %check_exists --file "%T/html/tree_map.html"

# Regression: the test result appears in the structural "Document tree map" but
# must be excluded from the "Requirements coverage" maps (an orphaned autogen
# TEST_RESULT node, whose non-normative test-suite parent is filtered out,
# blanks the chart). REQ-1 stays.
RUN: %cat "%T/html/tree_map.html" | filecheck %s --check-prefix CHECK-TREE-MAP

CHECK-TREE-MAP: <h2 class="section">Document tree map</h2>
CHECK-TREE-MAP: hello_world_crate::tests::add_works

CHECK-TREE-MAP: <h2 class="section">Requirements coverage with source</h2>
CHECK-TREE-MAP: REQ-1
CHECK-TREE-MAP-NOT: hello_world_crate::tests::add_works

CHECK-TREE-MAP: <h2 class="section">Requirements coverage with test</h2>
CHECK-TREE-MAP: REQ-1
CHECK-TREE-MAP-NOT: hello_world_crate::tests::add_works
